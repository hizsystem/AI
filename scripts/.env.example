# scripts/ 폴더 Python 스크립트용 환경변수 템플릿
#
# 사용법:
#   1. 이 파일을 .env로 복사: cp scripts/.env.example scripts/.env
#   2. 아래 값들을 실제 값으로 채움 (Supabase 대시보드 > Settings > API Keys)
#   3. 스크립트 실행 시: set -a && source scripts/.env && set +a && python3 scripts/{스크립트}.py
#
# ⚠️ scripts/.env는 .gitignore에 등록되어 있어 git에 절대 커밋되지 않음.
#    실수로 커밋했다면 즉시 Supabase에서 키 재발급할 것.

# --- GoVenture Forum Supabase ---
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_KEY=sb_secret_xxxxxxxxxxxxxxxxxxxxxxxx

# --- Vercel Blob (필요 시) ---
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxxxxxxxxxxxxxxxxxx
