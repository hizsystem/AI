{
  "brand": {
    "name": "brandrise",
    "name_kr": "브랜드라이즈",
    "logo_position": "top-right",
    "logo_style": "font-size: 22px; font-weight: 700; letter-spacing: 1px;"
  },

  "colors": {
    "primary": {
      "blue": "#2563EB",
      "blue_light": "#60A5FA",
      "blue_bg": "#EFF6FF"
    },
    "accent": {
      "orange": "#FF6B35",
      "green": "#16A34A",
      "green_light": "#4ADE80",
      "purple": "#7C3AED",
      "purple_light": "#A855F7",
      "yellow": "#FFD54F"
    },
    "neutral": {
      "white": "#FFFFFF",
      "gray_50": "#F9FAFB",
      "gray_100": "#F3F4F6",
      "gray_200": "#E2E8F0",
      "gray_300": "#D1D5DB",
      "gray_400": "#9CA3AF",
      "gray_500": "#6B7280",
      "gray_600": "#4B5563",
      "gray_700": "#374151",
      "gray_800": "#1F2937",
      "gray_900": "#0F172A",
      "black": "#0A0A0A"
    },
    "semantic": {
      "success": "#4ADE80",
      "warning": "#F59E0B",
      "error": "#EF4444",
      "info": "#60A5FA"
    }
  },

  "themes": {
    "dark": {
      "background": "linear-gradient(180deg, #0F172A 0%, #070B14 100%)",
      "text_primary": "#FFFFFF",
      "text_secondary": "#94A3B8",
      "text_muted": "#6B7280",
      "card_bg": "rgba(255,255,255,0.05)",
      "card_border": "rgba(255,255,255,0.1)",
      "logo_color": "rgba(255,255,255,0.4)"
    },
    "light": {
      "background": "linear-gradient(180deg, #EFF6FF 0%, #FFFFFF 50%, #EFF6FF 100%)",
      "text_primary": "#0F172A",
      "text_secondary": "#374151",
      "text_muted": "#9CA3AF",
      "card_bg": "#FFFFFF",
      "card_border": "#E2E8F0",
      "logo_color": "rgba(15,23,42,0.35)"
    },
    "black": {
      "background": "#0A0A0A",
      "text_primary": "#FFFFFF",
      "text_secondary": "#94A3B8",
      "text_muted": "#6B7280",
      "card_bg": "rgba(255,255,255,0.03)",
      "card_border": "rgba(255,255,255,0.08)",
      "logo_color": "rgba(255,255,255,0.4)"
    },
    "warm_light": {
      "background": "#F5F0EB",
      "text_primary": "#1A1A1A",
      "text_secondary": "#3D3D3D",
      "text_muted": "#9E9E9E",
      "card_bg": "#FFFFFF",
      "card_border": "rgba(0,0,0,0.06)",
      "logo_color": "rgba(26,26,26,0.35)"
    },
    "warm_accent": {
      "background": "#E8752E",
      "text_primary": "#1A1A1A",
      "text_secondary": "#4A2E1A",
      "text_muted": "rgba(26,26,26,0.5)",
      "card_bg": "rgba(0,0,0,0.08)",
      "card_border": "rgba(0,0,0,0.12)",
      "logo_color": "rgba(26,26,26,0.35)"
    }
  },

  "typography": {
    "font_family": "'Pretendard', -apple-system, sans-serif",
    "font_cdn": "https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.min.css",
    "sizes": {
      "headline_xl": "80px",
      "headline_lg": "72px",
      "headline_md": "56px",
      "headline_sm": "50px",
      "body_lg": "40px",
      "body_md": "34px",
      "body_sm": "30px",
      "caption": "24px",
      "small": "20px",
      "tag": "28px",
      "cta": "36px",
      "logo": "26px"
    },
    "weights": {
      "black": 900,
      "extrabold": 800,
      "bold": 700,
      "semibold": 600,
      "medium": 500,
      "regular": 400
    }
  },

  "layout": {
    "canvas": {
      "width": 1080,
      "height": 1080,
      "cardnews_height": 1350
    },
    "padding": {
      "content": "52px 64px",
      "content_bottom": "96px"
    },
    "components": {
      "tag": {
        "padding": "8px 20px",
        "border_radius": "100px",
        "margin_bottom": "24px"
      },
      "cta_bar": {
        "height": "80px",
        "position": "absolute bottom",
        "font_size": "26px",
        "font_weight": 700
      },
      "logo": {
        "position": "absolute top-40 right-48"
      },
      "card": {
        "border_radius": "16px",
        "padding": "28px 24px"
      }
    }
  },

  "cardnews_components": {
    "q_badge": { "size": 48, "bg": "#E8752E", "radius": 12, "color": "#FFFFFF" },
    "page_num": { "size": 22, "color": "#9E9E9E", "format": "03 / 10" },
    "terminal": { "bg": "#2D2D2D", "radius": 16, "dots": ["#FF5F57", "#FEBC2E", "#28C840"] },
    "color_bars": ["#F97316", "#3B82F6", "#8B5CF6", "#22C55E", "#EC4899", "#14B8A6"],
    "compare_before": { "bg": "linear-gradient(135deg, #FECACA, #FCA5A5)", "color": "#991B1B" },
    "compare_after": { "bg": "linear-gradient(135deg, #A7F3D0, #6EE7B7)", "color": "#065F46" },
    "insight_bar": { "bg": "linear-gradient(90deg, #F97316, #FB923C)", "color": "#FFFFFF" },
    "credit": { "size": 20, "color": "#9E9E9E", "text": "brandrise" }
  },

  "service_themes": {
    "brand_design": { "accent": "#60A5FA", "cta_bg": "#2563EB", "theme": "dark" },
    "oliveyoung": { "accent": "#16A34A", "cta_bg": "#16A34A", "theme": "light" },
    "performance": { "accent": "#FF6B35", "cta_bg": "#FF6B35", "theme": "black" },
    "viral": { "accent": "#A855F7", "cta_bg": "#7C3AED", "theme": "dark" },
    "success_stories": { "accent": "#2563EB", "cta_bg": "#2563EB", "theme": "light" },
    "wellness": { "accent": "#4ADE80", "cta_bg": "#22C55E", "theme": "black" }
  }
}
